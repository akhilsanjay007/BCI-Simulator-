# Version control — never send VCS metadata or LFS config into the image build context.
.git
.gitattributes
.github

# Large decoder weights (~2 GB) — mount at runtime (docker-compose volume, Railway volume)
# or set MODEL_PATH / DECODER_MODEL_PATH. Keeps build context small and fast.
models/*.pkl
models/**/*.pkl

# Python caches and envs
__pycache__
*.py[cod]
*$py.class
.pytest_cache
.mypy_cache
.ruff_cache
.venv
venv
env

# Coverage / test artifacts
.coverage
coverage.xml
htmlcov

# Secrets (never bake into images)
.env
.env.*

# Frontend belongs to its own image
frontend/

# Tests and CI-only files are not copied into the backend image
tests

# Editor / OS noise
.idea
.vscode
.cursor
*.swp
.DS_Store
Thumbs.db

# Documentation (smaller build context)
*.md

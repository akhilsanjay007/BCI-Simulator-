# Copy to .env for local overrides (never commit secrets). Docker Compose sets most defaults.

# --- Backend ---
ENV=development
# ENV=production

# Trained weights (Git LFS). Relative to process cwd (/app in Docker).
# MODEL_PATH=models/velocity_decoder.pkl
# DECODER_MODEL_PATH=models/velocity_decoder.pkl
# DECODER_REGRESSOR=ensemble

# Redis Streams (optional locally; enabled in docker-compose.yml)
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_SIGNALS=bci:signals
REDIS_STREAM_RETENTION_SECONDS=20
REDIS_MAX_CONNECTIONS=50

# CORS — comma-separated browser origins for the SPA (production / Railway)
# FRONTEND_URL=https://your-frontend.up.railway.app
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# Recording replay (Automatic mode — see recordings/*.json)
# BCI_RECORDINGS_DIR=recordings
# BCI_RECORDING_PATH=recordings/demo_1.json
# BCI_REPLAY=0

# --- Frontend (Vite build-time only) ---
# VITE_BACKEND_URL=http://localhost:8000

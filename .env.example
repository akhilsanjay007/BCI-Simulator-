# Copy to `.env` for local overrides (never commit secrets).
# Docker Compose already wires sane defaults for local development.

# ---------------------------------------------------------------------------
# Backend runtime
# ---------------------------------------------------------------------------
ENV=development
# ENV=production

# Decoder model artifact (Git LFS file; `/app` is Docker working directory)
# MODEL_PATH=models/velocity_decoder.pkl
# DECODER_MODEL_PATH=models/velocity_decoder.pkl
DECODER_REGRESSOR=ensemble
# DECODER_TRAIN_SAMPLES=25000

# Optional Redis Streams buffer (enabled automatically when REDIS_URL is set)
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_SIGNALS=bci:signals
REDIS_STREAM_RETENTION_SECONDS=20
REDIS_MAX_CONNECTIONS=50
# REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=1.0
# REDIS_SOCKET_TIMEOUT_SECONDS=1.0

# CORS: allow the dashboard origin(s)
# FRONTEND_URL=http://localhost:5173
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Replay source controls (automatic mode)
# BCI_RECORDINGS_DIR=recordings
# BCI_RECORDING_PATH=recordings/demo_1.json
# BCI_REPLAY=1
# PLAYBACK_LATENCY_BUFFER_MS=45

# ---------------------------------------------------------------------------
# Frontend build/runtime config
# ---------------------------------------------------------------------------
# Used by Vite at build time and by config template for static deployments.
# VITE_BACKEND_URL=http://localhost:8000
